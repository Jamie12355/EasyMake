# EasyMake Frontend Environment Variables
# IMPORTANT: Since this is a Vite pure-frontend, VITE_ prefixed variables will be exposed to the browser.
# For production, these should be moved to a backend Node.js proxy server. For local testing, this is fine.

# 1. Text Generation LLM (DeepSeek recommended)
VITE_LLM_API_KEY="sk-1a7aa6cf129f4256bfa6e4ea8533da14"
VITE_LLM_BASE_URL="https://api.deepseek.com"
VITE_LLM_MODEL="deepseek-chat"

# 2. Video API (Locked to Luma Ray Flash 2 for mixed-media style and cost control)
VITE_VIDEO_API_KEY="luma-580c0c8a-dd9e-4aae-a039-69e29f2220fc-877bf2f8-e75a-48a7-b738-61db901e895f1"
VITE_VIDEO_MODEL="ray-2-flash"