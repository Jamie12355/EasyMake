# EasyMake Frontend Environment Variables
# IMPORTANT: Since this is a Vite pure-frontend, VITE_ prefixed variables will be exposed to the browser.
# For production, these should be moved to a backend Node.js proxy server. For local testing, this is fine.

# 1. Text Generation LLM (e.g., DeepSeek, OpenAI, Ali Qwen)
VITE_LLM_API_KEY="your_llm_api_key_here"
VITE_LLM_BASE_URL="https://api.openai.com/v1" # Change if using DeepSeek/Qwen compatible endpoint

# 2. Video/Animation Generation Model (Minimax/Hailuo or Kling)
VITE_VIDEO_API_KEY="your_video_generation_api_key_here"
